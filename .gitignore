# secrets / tokens — never commit
*_token
*.env
secrets.local.*

# python noise
__pycache__/
.venv/
.codegraph/
dist/
.pytest_cache/
.ruff_cache/

# generated history snapshots (keep the current pointer)
data/history/*
!data/current.json

# local-only admin snapshot (traffic / PRs / security / Sentry) — never public
data/admin/
